# =====================================================
# Docker Ignore - Production Build
# =====================================================

# Dependencies
/vendor
/node_modules
/.npm

# Git
/.git
/.gitignore
/.gitattributes

# IDE
/.idea
/.vscode
/.vscode
/.fleet
/.nova
/.zed

# Environment files (keep only .env.docker for builds)
.env
.env.*
!.env.docker
!.env.example
!.env.production

# Logs & Cache
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*
*.log
*.cache

# OS
.DS_Store
Thumbs.db

# Database
*.sqlite
*.sqlite3

# Testing
.phpunit.result.cache
/.phpunit.cache
/tests

# Documentation
README.md
/docs
*.md

# Docker Compose (keep these for local dev)
docker-compose*.yml

# Dockerfile (keep for reference)
Dockerfile*
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
